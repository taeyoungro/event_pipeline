AWS_REGION=us-east-1
SECRET_API_KEY=my-super-secret-key
OUTPUT_BASE_DIR=/home/ec2-user/iam_pipeline/output
PAYLOAD_DIR=/home/ec2-user/iam_pipeline/payloads
WORK_BASE_DIR=/home/ec2-user/iam_pipeline/work
TF_STATE_BUCKET=nty-org-policy-terraform-state
TF_STATE_REGION=us-east-1
TF_STATE_LOCK_TABLE=nty-tf-state-lock
TF_PLUGIN_CACHE_DIR=/var/cache/terraform/plugins
DEBOUNCE_SECONDS=5
LOG_LEVEL=INFO
AUDIT_ROLE_NAME=AuditRole
ASSUME_ROLE_SESSION_NAME=iam-pipeline-codegen
ASSUME_ROLE_DURATION_SECONDS=900
INLINE_POLICY_MAX_CHARS=32000
